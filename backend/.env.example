# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/work2business

# JWT secret (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OpenAI API key (for AI plan generation)
OPENAI_API_KEY=sk-...

# Server port (default: 5000)
PORT=5000

# Environment
NODE_ENV=development

# Frontend URL (for password return links & CORS)
FRONTEND_URL=http://localhost:5173

# Backend URL (for payment webhooks)
BACKEND_URL=http://localhost:5000

# Chapa payment (required for real payments — get keys from https://dashboard.chapa.co)
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxx
# Optional: CHAPA_PUBLIC_KEY for future client-side integrations
CHAPA_PUBLIC_KEY=

# Email (optional - if not set, reset tokens are logged to console)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Work2Business <your@gmail.com>

# Default admin seed credentials (change before production)
ADMIN_EMAIL=admin@work2business.com
ADMIN_PASSWORD=Admin@12345
