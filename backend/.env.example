# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/work2business

# JWT secret (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OpenAI API key (for AI plan generation)
OPENAI_API_KEY=sk-...

# Server port (default: 5000)
PORT=5000

# Environment
NODE_ENV=development

# Frontend URL (for password reset email links)
FRONTEND_URL=http://localhost:5173

# Email (optional - if not set, reset tokens are logged to console)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Work2Business <your@gmail.com>
